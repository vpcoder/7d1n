<#+ 

	private void SaveOutput(string outputFileName) {
		var serviceProvider = this.Host as IServiceProvider;
		var dte = serviceProvider.GetService(typeof(EnvDTE.DTE)) as EnvDTE.DTE;
		var solutionDirectory = System.IO.Path.GetDirectoryName(dte.Solution.FullName);

	    outputFileName = solutionDirectory + "\\" + outputFileName;
		var stream = new StreamWriter(new FileStream(outputFileName, FileMode.Create));
			stream.Write(this.GenerationEnvironment.ToString());
		stream.Close();

		this.GenerationEnvironment.Remove(0, this.GenerationEnvironment.Length);
	}

	class MethodData
	{

		public string Name;
		public string Type;

		public List<ArgumentData> Arguments;

		public override string ToString()
        {
			return Type + " " + Name + "(" + string.Join(",", Arguments.Select(o => o.ToString()).ToArray()) + ")";
        }

    }

	class ArgumentData
    {
		public string Name;
		public string Type;

		public override string ToString()
		{
			return Type + " " + Name;
        }
    }

	List<MethodData> GetMethods(Type type)
	{
		var list = new List<MethodData>();

		var exclude = new []
		{
			"ExecuteAsync",
			"Validate",
			"Validate",
			"Dispose",
			"ToString",
			"Equals",
			"GetHashCode",
			"GetType"
        };

		foreach(var method in type.GetMethods())
        {
			if(method.IsPrivate)
				continue;

			if(method.Name.StartsWith("get_") || method.Name.StartsWith("set_"))
				continue;

			if(exclude.Contains(method.Name))
				continue;

			var tmp = new MethodData();
			tmp.Name = method.Name;
			tmp.Type = method.ReturnType==null ? "void" : method.ReturnType.Name;
			tmp.Arguments = GetArguments(method);
			list.Add(tmp);
        }

		return list;
    }

	List<ArgumentData> GetArguments(MethodInfo method)
    {
		var list = new List<ArgumentData>();

		foreach(var arg in method.GetParameters())
		{
			list.Add(GetArgument(arg));
		}

		return list;
    }

	ArgumentData GetArgument(ParameterInfo param)
	{
		return new ArgumentData()
		{
			Name = param.Name,
			Type = param.ParameterType.Name
        };
    }

	string GetClassName(Type type)
	{
		var name = type.Name;

		name = name.Replace("Controller", "");

		return name;
    }
#>