		#>using System;
using System.Linq;
using System.Collections.Generic;
using com.baensi.sdon.protocol.entities;
using com.baensi.sdon.clientapi.handlers.threading;

namespace com.baensi.sdon.clientapi.proxies
{

	public class <#=className#> : RestClient, I<#=className#>
	{

		public override string ControllerName { get; } = "<#=className#>";

		#region Ctor

		public <#=className#>(string host) : base (host)
		{ }

		#endregion

		#region API

		<#
		foreach(var method in methods)
		{
			#>/// <summary>
        /// Autogen Удалённый метод <#=method.Name#> контроллера <#=type.Name#>
        /// </summary>
		public <#=method.ToString()#>
		{
			return Proxy.Invoke<<#=method.Type#>>(ToURL("<#=method.Name#>"), <#=string.Join(",", method.Arguments.Select(o => o.Name).ToArray())#>);
		}
		
		/// <summary>
        /// Autogen Удалённый метод <#=method.Name#> контроллера <#=type.Name#>, работающий в параллельном потоке
        /// </summary>
		public void <#=method.Name#>Promise(<#=method.Arguments[0].Type#> <#=method.Arguments[0].Name#>, Action<<#=method.Type#>> callback, Action<Exception> exceptionCallback = null)
		{
			AsyncService.DoPromise(()=>
			{
				return <#=method.Name#>(<#=method.Arguments[0].Name#>);
			}, callback, exceptionCallback);
		}
		<#
		}#>

		#endregion

	}

}
<#
		SaveOutput("com.baensi.sdon.clientapi\\Api\\Managers\\"+className+".cs");
