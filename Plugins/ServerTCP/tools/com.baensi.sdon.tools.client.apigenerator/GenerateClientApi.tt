namespace com.baensi.sdon.clientapi
{

	public class WebApiFactory
	{
		
		#region Singleton

		private static Lazy<WebApiFactory> _instance = new Lazy<WebApiFactory>(() => new WebApiFactory(), true);

		public static WebApiFactory Instance
		{
			get
			{
				return _instance.Value;
			}
		}

		#endregion

		#region Shared Api Controllers

		<#=string.Join("\r\n\t\t", list.Select(o => "public " + GetClassName(o) + " " + GetClassName(o) + " { get; private set; }"))#>

		#endregion

		public void InitConnect(string host)
		{
<#
		foreach(var type in list)
		{
			var className = GetClassName(type);
		#>			this.<#=className#> = new <#=className#>(host);
<#
		}
		#>
		}
	}

}
