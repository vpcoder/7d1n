using System;
using System.Text;
using System.Linq;
using System.Collections.Generic;
using System.Data.Common;
using com.baensi.sdon.db.connection;
using com.baensi.sdon.db.dao.repository;
using com.baensi.sdon.db.dao.generator;
using com.baensi.sdon.db.entity;
using com.baensi.sdon.logic;
using NLog;

namespace com.baensi.sdon.db.dao
{

	// Autogen <#=table.Name#> DAO
	/// <summary>
    /// DAO таблицы '<#=table.SqlName#>', для работы с сущностью <#=table.Name#>
	/// Дата: <#=DateTime.Now.ToString()#>
    /// </summary>
	public class <#=table.Name#>Dao : DbAccess<<#=table.Name#>>
	{
		
		#region Ctors

		public <#=table.Name#>Dao() : base("<#=table.DbName+"."+table.SqlName#>")
		{ }

		#endregion

		private static readonly ILogger logger = LogManager.GetCurrentClassLogger();

		/// <summary>
        /// Создаёт пустую таблицу для указанной сущности, если такой ещё не существует
        /// </summary>
		public override void CreateTable()
		{
			var sql = $"CREATE TABLE IF NOT EXISTS <#=table.DbName+"."+table.SqlName#> "
					+ "("
						+ "id INT AUTO_INCREMENT,"
						+ "<#=string.Join(",\"\r\n						+ \"",table.Fields.Where(o=>o.Name!="Id").Select(o => o.SqlName + " " + o.SqlType).ToArray())#>,"
						+ "PRIMARY KEY (id)"
					+ ") ENGINE=INNODB;";
            MySqlConnector.Instance.OpenConnection((connection) =>
			{
				connection.Execute(sql);
			});
		}

		/// <summary>
        /// Удаляет записи с указанными идентификаторами из БД
        /// </summary>
        /// <param name="ids">Идентификаторы, по которым необходимо удалять записи</param>
		public override void Delete(params int[] ids)
        {
			var sql = $"DELETE FROM <#=table.DbName+"."+table.SqlName#> WHERE id IN ({string.Join(",",ids)});";
            MySqlConnector.Instance.OpenConnection((connection) =>
			{
				connection.Execute(sql);
			});
        }

		/// <summary>
        /// Читает запись из БД, и формирует сущность <#=table.Name#>, на основании этой записи
        /// </summary>
        /// <param name="reader">Поток чтения из БД</param>
		private <#=table.Name#> Read(DbDataReader reader)
		{
			return new <#=table.Name#>()
			{
<#
		var i = 0;
		foreach(var field in table.Fields)
        {
#>				<#=field.Name#> = <#=field.Type == "int" && field.Name=="Type" ? "(" + table.Name + "Type)" : ""#>reader.Get<#=field.MethodType#>(<#=i++#>),
<#
}
#>
			 };
		}

		/// <summary>
        /// Запрашивает из базы экземпляры конкретных сущностей <#=table.Name#>, по их идентификаторам
        /// </summary>
        /// <param name="ids">Идентификаторы запрашиваемых сущностей</param>
		public List<<#=table.Name#>> Get(params int[] ids)
        {
			var sql = $"SELECT * FROM <#=table.DbName+"."+table.SqlName#> WHERE id IN ({string.Join(",",ids)})";
			var entities = new List<<#=table.Name#>>();

			MySqlConnector.Instance.OpenConnection((connection) =>
			{
				using(var reader = connection.ExecuteReader(sql))
				{
					while(reader.Read())
					{
						entities.Add(Read(reader));
					}
					reader.Close();
				}
			});

			if(entities.Count!=ids.Length)
				throw new Exception("Select by ids exception");

			return entities;
        }

        public override <#=table.Name#> Get(int id)
        {
			return Get(new[] { id })[0];
        }

        public override IEnumerable<<#=table.Name#>> GetAll()
        {
            var sql = $"SELECT * FROM <#=table.DbName+"."+table.SqlName#>";
			var list = new List<<#=table.Name#>>();

            MySqlConnector.Instance.OpenConnection((connection) =>
			{
				using(var reader = connection.ExecuteReader(sql))
				{
					for(;;)
					{
						if(!reader.Read())
							break;
						list.Add(Read(reader));
					}
					reader.Close();
				}
			});

			return list;
        }

        public override int[] Insert(IEnumerable<<#=table.Name#>> items)
        {
			var list = items.ToList();
			var sql = new StringBuilder(4096);
			var ids = new int[list.Count];

			MySqlConnector.Instance.OpenConnection((connection) =>
			{
				var i = 0;
				foreach(var item in list)
				{
					sql.Append("INSERT INTO <#=table.DbName+"."+table.SqlName#>")
					   .Append(" (<#=string.Join(",",table.Fields.Where(o=> o.Name!="Id").Select(o => table.DbName+"."+table.SqlName + "." + o.Name).ToArray())#>)")
					   .Append(" VALUES (")
					   <#
					   var countInsert = 0;
					   foreach(var field in table.Fields)
                       {
							if(field.Name=="Id")
								continue;
					   #>.Append(<#=GetValue(field,"item")#>)<#=countInsert++ > table.Fields.Count-3? "" : ".Append(\",\")"#>
					   <#
                       }
					   #>.Append(");");
				
					connection.Execute(sql.ToString());

					ids[i++] = _generator.Next;

					sql.Clear();
				}
			});
			return ids;
        }

        public override int Insert(<#=table.Name#> item)
        {
            return Insert(new[] { item })[0];
        }

        public override void Update(IEnumerable<<#=table.Name#>> items)
        {
			var sql = new StringBuilder(4096);
			MySqlConnector.Instance.OpenConnection((connection) =>
			{
				foreach(var item in items)
				{
					sql.Append("UPDATE <#=table.DbName+"."+table.SqlName#>")
					   .Append(" SET ")
					   <#
					   var countUpdate = 0;
					   foreach(var field in table.Fields)
                       {
							if(field.Name=="Id")
								continue;
					   #>.Append("<#=table.DbName+"."+table.SqlName+"."+field.SqlName#>=").Append(<#=GetValue(field,"item")#>)<#=countUpdate++ > table.Fields.Count-3? "" : ".Append(\",\")"#>
					   <#
                       }
					   #>.Append(" WHERE id=").Append(item.Id).Append(")");
					connection.Execute(sql.ToString());
					sql.Clear();
				}
			});
        }

        public override void Update(<#=table.Name#> item)
        {
            Update(new[] { item });
        }

	}

	// Autogen <#=table.Name#> Repository
	public class <#=table.Name#>Repository : RepositoryBase<<#=table.Name#>>
	{
		
		private static readonly ILogger logger = LogManager.GetCurrentClassLogger();

		public <#=table.Name#>Repository() : base(new <#=table.Name#>Dao())
		{
			logger.Debug($"init <#=table.Name#> repository with {_cache.Count} items");
		}

	}

}

public static class DbEntity<#=table.Name#>Additions
{

    public static IEnumerable<com.baensi.sdon.protocol.entities.<#=table.Name#>> ToTransport(this IEnumerable<<#=table.Name#>> entities)
	{
		var list = new List<com.baensi.sdon.protocol.entities.<#=table.Name#>>();

		foreach(var entity in entities)
			list.Add(entity.Transport);

		return list;
	}

}

